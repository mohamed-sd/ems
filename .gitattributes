# Git Attributes Configuration
# Enforce consistent line endings and encoding across all platforms

# Auto detect and normalize line endings to LF
* text=auto eol=lf

# Force Unix line endings for specific file types
*.php text eol=lf
*.js text eol=lf
*.css text eol=lf
*.json text eol=lf
*.sql text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.html text eol=lf
*.xml text eol=lf
*.ps1 text eol=lf
*.sh text eol=lf

# Binary files
*.jpg binary
*.jpeg binary
*.png binary
*.gif binary
*.ico binary
*.zip binary
*.tar binary
*.gz binary
*.exe binary
*.dll binary
*.so binary

# Ensure PHP files are always UTF-8 without BOM
*.php diff=php working-tree-encoding=UTF-8 encoding=UTF-8
