# ═══════════════════════════════════════════════════════════════════════════
# EMS Security Configuration - .htaccess (Simplified & Fixed)
# تكوين أمان Apache للنظام - نسخة مبسطة وآمنة
# @version 2.2 - Fixed 403 Forbidden Issue
# @date 2026-03-01
# ═══════════════════════════════════════════════════════════════════════════

# السماح بالوصول للموقع ومنع عرض محتوى المجلدات
Options -Indexes +FollowSymLinks
DirectoryIndex index.php index.html

# ═══════════════════════════════════════════════════════════════════════════
# 1. حماية الملفات الحساسة
# ═══════════════════════════════════════════════════════════════════════════

# منع الوصول لملفات .htaccess و .env
<FilesMatch "^\.(htaccess|htpasswd|env)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
</FilesMatch>

# منع الوصول لملفات النسخ الاحتياطي وقواعد البيانات
<FilesMatch "\.(bak|backup|old|orig|save|swp|tmp|sql|log)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
</FilesMatch>

# ═══════════════════════════════════════════════════════════════════════════
# 2. Security Headers (اختياري - قد يسبب مشاكل في بعض الحالات)
# ═══════════════════════════════════════════════════════════════════════════

# معطلة حالياً - يتم تطبيقها من PHP في security.php
# <IfModule mod_headers.c>
#     Header always set X-Frame-Options "DENY"
#     Header always set X-Content-Type-Options "nosniff"
#     Header always set X-XSS-Protection "1; mode=block"
# </IfModule>

# ═══════════════════════════════════════════════════════════════════════════
# 3. تحسين الأداء (Caching)
# ═══════════════════════════════════════════════════════════════════════════

<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType text/javascript "access plus 1 month"
    ExpiresByType application/json "access plus 1 day"
    ExpiresByType text/html "access plus 5 minutes"
</IfModule>

<IfModule mod_headers.c>
    <FilesMatch "\.(css|js|jpg|jpeg|png|gif|webp|svg|ico)$">
        Header set Cache-Control "public, max-age=2592000"
    </FilesMatch>
</IfModule>

# ═══════════════════════════════════════════════════════════════════════════
# 4. Compression للأداء
# ═══════════════════════════════════════════════════════════════════════════

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript application/javascript application/json application/xml image/svg+xml
</IfModule>

# ═══════════════════════════════════════════════════════════════════════════
# END OF .htaccess - نسخة مبسطة وآمنة
# ═══════════════════════════════════════════════════════════════════════════

